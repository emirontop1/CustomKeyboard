<?xml version="1.0" encoding="utf-8"?>
<!--
    res/layout/keyboard_view.xml
    ════════════════════════════
    Root layout inflated by MyCustomKeyboardService.onCreateInputView().

    The <android.inputmethodservice.KeyboardView> widget does the heavy
    lifting: it renders keys from the loaded Keyboard XML and fires
    OnKeyboardActionListener callbacks.

    ── Visual customisation ──────────────────────────────────────────
    • android:background          → keyboard panel background colour / drawable
    • android:keyBackground       → individual key background (selector drawable)
    • android:keyTextColor        → key label text colour
    • android:keyTextSize         → key label text size
    • android:labelTextSize       → multi-character label text size (e.g. "?123")
    • android:shadowColor         → shadow beneath key labels
    • android:shadowRadius        → shadow blur radius
    • android:keyPreviewLayout    → layout for the pop-up preview bubble
    ─────────────────────────────────────────────────────────────────
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background">

    <!-- Suggestion strip (hidden by default; set visibility="visible" to enable) -->
    <include
        layout="@layout/suggestion_strip"
        android:visibility="gone" />

    <!-- The actual keyboard widget -->
    <android.inputmethodservice.KeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/keyboard_background"
        android:keyBackground="@drawable/key_background"
        android:keyTextColor="@color/key_text"
        android:keyTextSize="@dimen/key_text_size"
        android:labelTextSize="@dimen/key_label_text_size"
        android:shadowColor="@color/key_shadow"
        android:shadowRadius="2.5"
        android:keyPreviewLayout="@layout/key_preview"
        android:paddingBottom="@dimen/keyboard_bottom_padding" />

</LinearLayout>
