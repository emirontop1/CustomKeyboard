<?xml version="1.0" encoding="utf-8"?>
<!--
    res/layout/key_preview.xml
    ══════════════════════════
    The pop-up bubble shown above a key while it is pressed.
    Android's KeyboardView inflates this automatically when
    android:keyPreviewLayout is set.
-->
<TextView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="@dimen/key_preview_min_width"
    android:gravity="center"
    android:textColor="@color/key_preview_text"
    android:textSize="@dimen/key_preview_text_size"
    android:background="@drawable/key_preview_background"
    android:padding="8dp" />
