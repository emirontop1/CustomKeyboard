<?xml version="1.0" encoding="utf-8"?>
<!--
    res/xml/symbols_shift.xml
    ═════════════════════════
    Second symbols page (shifted): extended / less common characters
    Row 1 : ~ ` | • √ π ÷ × ¶ ∆
    Row 2 : £ ¢ € ¥ ^ ° = { }
    Row 3 : ⇧(back)  \  /  <  >  [  ]  _  ⌫
    Row 4 : ABC  ,  [SPACE]  .  ↵
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="@dimen/key_height"
    android:horizontalGap="@dimen/key_horizontal_gap"
    android:verticalGap="@dimen/key_vertical_gap">

    <!-- ── Row 1 ──────────────────────────────────────────────────── -->
    <Row>
        <Key android:codes="126" android:keyLabel="~"  android:keyEdgeFlags="left" />
        <Key android:codes="96"  android:keyLabel="`" />
        <Key android:codes="124" android:keyLabel="|" />
        <Key android:codes="8226" android:keyLabel="•" />
        <Key android:codes="8730" android:keyLabel="√" />
        <Key android:codes="960"  android:keyLabel="π" />
        <Key android:codes="247"  android:keyLabel="÷" />
        <Key android:codes="215"  android:keyLabel="×" />
        <Key android:codes="182"  android:keyLabel="¶" />
        <Key android:codes="8710" android:keyLabel="∆" android:keyEdgeFlags="right" />
    </Row>

    <!-- ── Row 2 ──────────────────────────────────────────────────── -->
    <Row>
        <Key android:codes="163"  android:keyLabel="£" android:keyEdgeFlags="left" />
        <Key android:codes="162"  android:keyLabel="¢" />
        <Key android:codes="8364" android:keyLabel="€" />
        <Key android:codes="165"  android:keyLabel="¥" />
        <Key android:codes="94"   android:keyLabel="^" />
        <Key android:codes="176"  android:keyLabel="°" />
        <Key android:codes="61"   android:keyLabel="=" />
        <Key android:codes="123"  android:keyLabel="{" />
        <Key android:codes="125"  android:keyLabel="}" />
        <Key android:codes="92"   android:keyLabel="\\" android:keyEdgeFlags="right" />
    </Row>

    <!-- ── Row 3 ──────────────────────────────────────────────────── -->
    <Row>
        <Key
            android:codes="-1"
            android:keyLabel="@string/key_label_sym"
            android:keyEdgeFlags="left"
            android:keyWidth="15%p"
            android:isModifier="true" />
        <Key android:codes="47"   android:keyLabel="/"  android:keyWidth="10%p" />
        <Key android:codes="60"   android:keyLabel="&lt;"  android:keyWidth="10%p" />
        <Key android:codes="62"   android:keyLabel="&gt;"  android:keyWidth="10%p" />
        <Key android:codes="91"   android:keyLabel="["  android:keyWidth="10%p" />
        <Key android:codes="93"   android:keyLabel="]"  android:keyWidth="10%p" />
        <Key android:codes="95"   android:keyLabel="_"  android:keyWidth="10%p" />
        <Key android:codes="8230" android:keyLabel="…"  android:keyWidth="10%p" />
        <Key
            android:codes="-5"
            android:keyLabel="⌫"
            android:keyIcon="@drawable/ic_delete"
            android:keyEdgeFlags="right"
            android:keyWidth="15%p"
            android:isRepeatable="true" />
    </Row>

    <!-- ── Row 4 ──────────────────────────────────────────────────── -->
    <Row android:rowEdgeFlags="bottom">
        <Key
            android:codes="-2"
            android:keyLabel="@string/key_label_abc"
            android:keyEdgeFlags="left"
            android:keyWidth="15%p" />
        <Key android:codes="44" android:keyLabel="," android:keyWidth="10%p" />
        <Key android:codes="32" android:keyLabel="SPACE" android:keyWidth="40%p" />
        <Key android:codes="46" android:keyLabel="." android:keyWidth="10%p" />
        <Key
            android:codes="-4"
            android:keyLabel="↵"
            android:keyIcon="@drawable/ic_enter"
            android:keyEdgeFlags="right"
            android:keyWidth="25%p" />
    </Row>

</Keyboard>
