<?xml version="1.0" encoding="utf-8"?>
<!--
    res/xml/qwerty.xml
    ══════════════════
    Standard QWERTY layout with:
      Row 1 : Q W E R T Y U I O P
      Row 2 : A S D F G H J K L
      Row 3 : ⇧(shift) Z X C V B N M ⌫(delete)
      Row 4 : ?123 , [SPACE] . ↵(enter)

    ── Customisation guide ────────────────────────────────────────────
    • keyWidth          → percentage of row width (e.g. "10%p")
    • android:keyHeight → actual dp height of each row
    • keyLabel          → character shown on keycap
    • codes             → ASCII/Unicode value sent on tap (comma-separated for alternatives)
    • isRepeatable      → keep firing while key held (useful for delete)
    • keyEdgeFlags      → "left" or "right" to anchor edge keys
    ──────────────────────────────────────────────────────────────────
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="@dimen/key_height"
    android:horizontalGap="@dimen/key_horizontal_gap"
    android:verticalGap="@dimen/key_vertical_gap">

    <!-- ── Row 1: Q W E R T Y U I O P ──────────────────────────── -->
    <Row>
        <Key android:codes="113" android:keyLabel="q" android:keyEdgeFlags="left" />
        <Key android:codes="119" android:keyLabel="w" />
        <Key android:codes="101" android:keyLabel="e" />
        <Key android:codes="114" android:keyLabel="r" />
        <Key android:codes="116" android:keyLabel="t" />
        <Key android:codes="121" android:keyLabel="y" />
        <Key android:codes="117" android:keyLabel="u" />
        <Key android:codes="105" android:keyLabel="i" />
        <Key android:codes="111" android:keyLabel="o" />
        <Key android:codes="112" android:keyLabel="p" android:keyEdgeFlags="right" />
    </Row>

    <!-- ── Row 2: A S D F G H J K L ────────────────────────────── -->
    <Row>
        <!-- 5% left gap to centre the 9-key row -->
        <Key
            android:codes="97"
            android:keyLabel="a"
            android:keyEdgeFlags="left"
            android:keyWidth="10%p"
            android:horizontalGap="5%p" />
        <Key android:codes="115" android:keyLabel="s" />
        <Key android:codes="100" android:keyLabel="d" />
        <Key android:codes="102" android:keyLabel="f" />
        <Key android:codes="103" android:keyLabel="g" />
        <Key android:codes="104" android:keyLabel="h" />
        <Key android:codes="106" android:keyLabel="j" />
        <Key android:codes="107" android:keyLabel="k" />
        <Key
            android:codes="108"
            android:keyLabel="l"
            android:keyEdgeFlags="right"
            android:keyWidth="10%p" />
    </Row>

    <!-- ── Row 3: Shift  Z X C V B N M  Delete ──────────────────── -->
    <Row>
        <!-- Shift key -->
        <Key
            android:codes="-1"
            android:keyLabel="⇧"
            android:keyIcon="@drawable/ic_shift"
            android:keyEdgeFlags="left"
            android:keyWidth="15%p"
            android:isModifier="true"
            android:isSticky="false" />

        <Key android:codes="122" android:keyLabel="z" android:keyWidth="10%p" />
        <Key android:codes="120" android:keyLabel="x" android:keyWidth="10%p" />
        <Key android:codes="99"  android:keyLabel="c" android:keyWidth="10%p" />
        <Key android:codes="118" android:keyLabel="v" android:keyWidth="10%p" />
        <Key android:codes="98"  android:keyLabel="b" android:keyWidth="10%p" />
        <Key android:codes="110" android:keyLabel="n" android:keyWidth="10%p" />
        <Key android:codes="109" android:keyLabel="m" android:keyWidth="10%p" />

        <!-- Delete key -->
        <Key
            android:codes="-5"
            android:keyLabel="⌫"
            android:keyIcon="@drawable/ic_delete"
            android:keyEdgeFlags="right"
            android:keyWidth="15%p"
            android:isRepeatable="true" />
    </Row>

    <!-- ── Row 4: Symbols  ,  [SPACE]  .  Enter ─────────────────── -->
    <Row android:rowEdgeFlags="bottom">
        <!-- Switch to symbols -->
        <Key
            android:codes="-2"
            android:keyLabel="?123"
            android:keyEdgeFlags="left"
            android:keyWidth="15%p" />

        <Key android:codes="44" android:keyLabel="," android:keyWidth="10%p" />

        <!-- Space bar - takes the remaining centre width -->
        <Key
            android:codes="32"
            android:keyLabel="SPACE"
            android:keyWidth="40%p"
            android:isRepeatable="false" />

        <Key android:codes="46" android:keyLabel="." android:keyWidth="10%p" />

        <!-- Enter / Done -->
        <Key
            android:codes="-4"
            android:keyLabel="↵"
            android:keyIcon="@drawable/ic_enter"
            android:keyEdgeFlags="right"
            android:keyWidth="25%p" />
    </Row>

</Keyboard>
