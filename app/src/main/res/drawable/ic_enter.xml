<?xml version="1.0" encoding="utf-8"?>
<!--
    res/drawable/ic_enter.xml
    ═══════════════════════════
    Return / Enter key icon (↵ style bent arrow).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="@color/key_text">

    <!-- Horizontal bar going right, then down, then left with arrowhead -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@color/key_text"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M20,8 V13 H4" />

    <!-- Arrowhead pointing left -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@color/key_text"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M8,9 L4,13 L8,17" />

</vector>
