<?xml version="1.0" encoding="utf-8"?>
<!--
    res/values/colors.xml
    ══════════════════════
    All colours used by the keyboard and Settings UI.
    Change these values to retheme the entire app in one place.

    Dark theme colours live in res/values-night/colors.xml (create that
    file and override any values here to support system dark mode).
-->
<resources>

    <!-- ── Brand / Accent ────────────────────────────────────────── -->
    <color name="accent">#4F8EF7</color>
    <color name="accent_dark">#2C6DD5</color>

    <!-- ── Keyboard panel ────────────────────────────────────────── -->
    <!-- Background of the entire keyboard panel -->
    <color name="keyboard_background">#1C1C1E</color>

    <!-- ── Key colours ───────────────────────────────────────────── -->
    <!-- Normal key background (light tones on dark panel) -->
    <color name="key_normal_background">#2C2C2E</color>
    <!-- Pressed state -->
    <color name="key_pressed_background">#48484A</color>
    <!-- Special keys: shift, delete, switch, enter -->
    <color name="key_special_background">#3A3A3C</color>
    <!-- Space bar -->
    <color name="key_space_background">#636366</color>
    <!-- Key label text -->
    <color name="key_text">#FFFFFF</color>
    <!-- Shadow beneath key labels -->
    <color name="key_shadow">#40000000</color>
    <!-- Thin divider line between suggestion strip items -->
    <color name="key_divider">#3A3A3C</color>

    <!-- ── Suggestion strip ───────────────────────────────────────── -->
    <color name="suggestion_strip_background">#1C1C1E</color>
    <color name="suggestion_highlight">#4F8EF7</color>

    <!-- ── Key preview popup ─────────────────────────────────────── -->
    <color name="key_preview_background">#4F8EF7</color>
    <color name="key_preview_text">#FFFFFF</color>

    <!-- ── Settings / Launcher Activity ─────────────────────────── -->
    <color name="settings_background">#F2F2F7</color>
    <color name="settings_text_primary">#1C1C1E</color>
    <color name="settings_text_secondary">#8E8E93</color>
    <color name="card_background">#FFFFFF</color>

    <!-- Material theme required colours -->
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">#FF6200EE</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="teal_200">#FF03DAC5</color>
    <color name="teal_700">#FF018786</color>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

</resources>
